<?xml version="1.0"?>
<extension key="uk.charity.importer" type="module">
  <file>charityimporter</file>
  <name>uk.charity.importer</name>
  <description>Import UK charity data from external database into CiviCRM organizations</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>benm</author>
    <email>ben@benmango.co.uk</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">http://FIXME</url>
    <url desc="Documentation">http://FIXME</url>
    <url desc="Support">http://FIXME</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2025-08-10</releaseDate>
  <version>1.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.5</ver>
  </compatibility>
  <comments>Imports charity data with proper address, contact, and custom field mapping</comments>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/Charityimporter</namespace>
    <format>23.02.1</format>
    <angularModule>crmCharityimporter</angularModule>
  </civix>
  <mixins>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty-v2@1.0.1</mixin>
  </mixins>
</extension>
